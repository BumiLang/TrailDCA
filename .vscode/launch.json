  "version": "0.2.0",
  "configurations": [
    {
      // Runs as `python -m src.main` (not `src/main.py` directly) so the
      // `from src import ...` absolute imports in main.py resolve correctly.
      "name": "TrailDCA: run (dry-run per .env)",
      "type": "debugpy",
      "request": "launch",
      "module": "src.main",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
