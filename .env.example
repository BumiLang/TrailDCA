# Toss Securities OpenAPI (https://developers.tossinvest.com/docs)
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=
# Optional: pin a specific account. If unset, the first account from GET /api/v1/accounts is used.
TOSS_ACCOUNT_SEQ=

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
GOOGLE_SHEET_ID=1OP20AeVjn8g6WIB65uLB49reioEHOnnjff9sa3q0TQw
GOOGLE_SHEET_TAB=Sheet1

# Safety switch. Must be explicitly set to "true" to place real orders.
LIVE_TRADING=false

LOG_LEVEL=INFO
# DEBUG
# INFO (기본값, .env에 설정 안 하면 이걸로 동작)
# WARNING
# ERROR
# CRITICAL